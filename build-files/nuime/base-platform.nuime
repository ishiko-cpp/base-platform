<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="https://nuime.org/schema/core/1">
  <name>base-platform</name>
  <targets>
    <target>
      <name>base-platform-lib</name>
      <labels>
        <label>nuime:product</label>
      </labels>
      <properties>
        <property name="nuime:test-suite">
          <target-ref>
            <location>
              <url>https://github.com/ishiko-cpp/base-platform/tests/build-files/nuime/base-platform-tests.nuime</url>
            </location>
            <name>base-platform-tests</name>
          </target-ref>
        </property>
      </properties>
    </target>
  </targets>
  <subprojects>
    <subproject>
      <name>base-platform-tests</name>
      <labels>
        <label>nuime:tests</label>
      </labels>
      <location>
        <url>https://github.com/ishiko-cpp/base-platform/tests/build-files/nuime/base-platform-tests.nuime</url>
      </location>
    </subproject>
  </subprojects>
</project>
